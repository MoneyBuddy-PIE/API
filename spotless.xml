<?xml version="1.0" encoding="UTF-8"?>
<spotless>
    <java>
        <!-- Formatage avec Google Java Format -->
        <googleJavaFormat/>
        
        <!-- Nettoyage des imports inutilisés -->
        <removeUnusedImports/>
        
        <!-- Tri et ordre des imports personnalisé -->
        <importOrder>
            <order>java, javax, org, com</order>
        </importOrder>
        
        <!-- En-têtes de licence -->
        <licenseHeader>
            <content>/*
 * Copyright ${project.groupId} ${project.artifactId}
 */</content>
        </licenseHeader>
        
        <!-- Fichiers à inclure/exclure -->
        <includes>
            <include>**/*.java</include>
        </includes>
        <excludes>
            <exclude>**/generated/**</exclude>
            <exclude>**/*Test.java</exclude>
            <exclude>**/target/**</exclude>
            <exclude>**/migrations/**</exclude>
        </excludes>
    </java>
    
    <!-- Formatage XML (pom.xml, application.yml, etc.) -->
    <xml>
        <eclipse/>
        <includes>
            <include>**/*.xml</include>
            <include>pom.xml</include>
        </includes>
    </xml>
    
    <!-- Formatage YAML -->
    <yaml>
        <indent size="2"/>
        <includes>
            <include>**/*.yml</include>
            <include>**/*.yaml</include>
        </includes>
    </yaml>
</spotless>
